{
  "name": "full-bazodiac-fufire",
  "version": "1.0.0",
  "description": "Railway-deployable FuFirE dashboard and proxy connected to the FuFirE API.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "test": "node --test 'test/*.test.js'",
    "test:contract": "FUFIRE_CONTRACT_TEST=true node --test test/contract.test.js",
    "test:e2e": "playwright test --config=playwright.config.mjs",
    "test:e2e:update": "playwright test --config=playwright.config.mjs --update-snapshots",
    "test:e2e:headed": "playwright test --config=playwright.config.mjs --headed",
    "test:e2e:desktop": "playwright test --config=playwright.config.mjs --project=chromium-desktop",
    "test:e2e:mobile": "playwright test --config=playwright.config.mjs --project=chromium-mobile"
  },
  "keywords": [
    "fufire",
    "railway",
    "bazi",
    "astrology"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "jsdom": "^29.1.1"
  }
}
