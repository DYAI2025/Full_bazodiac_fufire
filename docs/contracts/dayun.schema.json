{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fufire.example/schemas/calculate/bazi/dayun.response.schema.json",
  "title": "DaYunResponse",
  "description": "Successful response contract for POST /calculate/bazi/dayun. Returns the resolved decade pillars (Da Yun), provenance, precision metadata and any non-fatal warnings. Error responses (e.g. missing direction basis under strict=true) are described by dayun.error.schema.json. Mirrored byte-identically at `bazodiac-dayun/docs/contracts/dayun.schema.json` — keep in sync (CI check pending). TODO: replace `$id` host before production release.",
  "type": "object",
  "additionalProperties": false,
  "required": ["dayun", "provenance", "precision", "warnings"],
  "$defs": {
    "StemEnum": {
      "type": "string",
      "description": "Ten Heavenly Stems in Pinyin (Jia, Yi, Bing, Ding, Wu, Ji, Geng, Xin, Ren, Gui). Note: stem `Wu` (Pinyin for 戊, yang earth) is spelt identically to branch `Wu` (Pinyin for 午, horse) — they are different characters and live in different fields, so there is no contract collision.",
      "enum": ["Jia", "Yi", "Bing", "Ding", "Wu", "Ji", "Geng", "Xin", "Ren", "Gui"]
    },
    "BranchEnum": {
      "type": "string",
      "description": "Twelve Earthly Branches in Pinyin (Zi, Chou, Yin, Mao, Chen, Si, Wu, Wei, Shen, You, Xu, Hai). See StemEnum description for the Wu/Wu spelling collision note.",
      "enum": ["Zi", "Chou", "Yin", "Mao", "Chen", "Si", "Wu", "Wei", "Shen", "You", "Xu", "Hai"]
    },
    "TenGodEnum": {
      "type": "string",
      "description": "Canonical ten Shen (Ten Gods) in Pinyin with a space between syllables.",
      "enum": [
        "Bi Jian",
        "Jie Cai",
        "Shi Shen",
        "Shang Guan",
        "Pian Cai",
        "Zheng Cai",
        "Qi Sha",
        "Zheng Guan",
        "Pian Yin",
        "Zheng Yin"
      ]
    },
    "JieqiEnum": {
      "type": "string",
      "description": "Twenty-four solar terms (jieqi) in Pinyin, two-syllable names separated by a space. Ordered starting from Li Chun (Start of Spring).",
      "enum": [
        "Li Chun",
        "Yu Shui",
        "Jing Zhe",
        "Chun Fen",
        "Qing Ming",
        "Gu Yu",
        "Li Xia",
        "Xiao Man",
        "Mang Zhong",
        "Xia Zhi",
        "Xiao Shu",
        "Da Shu",
        "Li Qiu",
        "Chu Shu",
        "Bai Lu",
        "Qiu Fen",
        "Han Lu",
        "Shuang Jiang",
        "Li Dong",
        "Xiao Xue",
        "Da Xue",
        "Dong Zhi",
        "Xiao Han",
        "Da Han"
      ]
    },
    "Pillar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stem", "branch", "element", "polarity", "index60"],
      "properties": {
        "stem": {
          "allOf": [{ "$ref": "#/$defs/StemEnum" }],
          "description": "Heavenly stem in pinyin (e.g. 'Jia')."
        },
        "branch": {
          "allOf": [{ "$ref": "#/$defs/BranchEnum" }],
          "description": "Earthly branch in pinyin (e.g. 'Chen')."
        },
        "stem_cn": { "type": "string", "description": "Heavenly stem in Chinese characters." },
        "branch_cn": { "type": "string", "description": "Earthly branch in Chinese characters." },
        "element": {
          "type": "string",
          "enum": ["wood", "fire", "earth", "metal", "water"],
          "description": "Five-element label for the stem."
        },
        "polarity": {
          "type": "string",
          "enum": ["yin", "yang"]
        },
        "index60": {
          "type": "integer",
          "minimum": 0,
          "maximum": 59,
          "description": "Position in the 60-pillar sexagenary cycle (jiazi)."
        }
      }
    },
    "RelationToDayMaster": {
      "type": "object",
      "additionalProperties": false,
      "required": ["day_master", "ten_god", "element_relation", "label_de"],
      "properties": {
        "day_master": {
          "allOf": [{ "$ref": "#/$defs/StemEnum" }],
          "description": "Pinyin name of the day-master stem (e.g. 'Wu')."
        },
        "ten_god": {
          "allOf": [{ "$ref": "#/$defs/TenGodEnum" }],
          "description": "Ten-Gods label for this decade pillar's stem relative to the day master (e.g. 'Qi Sha')."
        },
        "element_relation": {
          "type": "string",
          "enum": [
            "same_element",
            "produced_by_day_master",
            "controlled_by_day_master",
            "controls_day_master",
            "produces_day_master"
          ]
        },
        "label_de": { "type": "string", "description": "Short German label of the relation (e.g. 'Druck / Struktur')." }
      }
    },
    "Cycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence",
        "age_start",
        "age_end",
        "date_start",
        "date_end",
        "pillar",
        "relation_to_day_master",
        "is_current"
      ],
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 1,
          "description": "1-based ordinal of the decade in the returned series."
        },
        "age_start": { "type": "number", "description": "Inclusive decimal-years age at which this decade begins." },
        "age_end": { "type": "number", "description": "Exclusive decimal-years age at which this decade ends." },
        "date_start": { "type": "string", "format": "date" },
        "date_end": { "type": "string", "format": "date" },
        "pillar": { "$ref": "#/$defs/Pillar" },
        "relation_to_day_master": { "$ref": "#/$defs/RelationToDayMaster" },
        "is_current": { "type": "boolean" }
      }
    },
    "SemanticSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["road_metaphor", "supports", "frictions", "practice"],
      "properties": {
        "road_metaphor": { "type": "string" },
        "supports": { "type": "array", "items": { "type": "string" } },
        "frictions": { "type": "array", "items": { "type": "string" } },
        "practice": { "type": "array", "items": { "type": "string" } }
      }
    },
    "CurrentCycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "age_start", "age_end", "pillar", "semantic_summary"],
      "properties": {
        "sequence": { "type": "integer", "minimum": 1 },
        "age_start": { "type": "number" },
        "age_end": { "type": "number" },
        "pillar": { "$ref": "#/$defs/Pillar" },
        "semantic_summary": { "$ref": "#/$defs/SemanticSummary" }
      }
    },
    "AnchorTerm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "direction", "local_dt"],
      "properties": {
        "name": {
          "allOf": [{ "$ref": "#/$defs/JieqiEnum" }],
          "description": "Pinyin name of the solar term used as anchor (e.g. 'Xiao Shu')."
        },
        "direction": {
          "type": "string",
          "enum": ["next", "previous"],
          "description": "Whether the anchor is the next or previous jieqi relative to birth."
        },
        "local_dt": { "type": "string", "format": "date-time" }
      }
    },
    "DeltaToAnchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["days", "hours", "minutes"],
      "properties": {
        "days": { "type": "integer", "minimum": 0 },
        "hours": { "type": "integer", "minimum": 0, "maximum": 23 },
        "minutes": { "type": "integer", "minimum": 0, "maximum": 59 }
      }
    },
    "StartAge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["years", "months", "days", "decimal_years"],
      "properties": {
        "years": { "type": "integer", "minimum": 0 },
        "months": { "type": "integer", "minimum": 0, "maximum": 11 },
        "days": { "type": "integer", "minimum": 0, "maximum": 30 },
        "decimal_years": { "type": "number", "minimum": 0 }
      }
    },
    "Start": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anchor_term", "delta", "start_age", "method"],
      "properties": {
        "anchor_term": { "$ref": "#/$defs/AnchorTerm" },
        "delta": { "$ref": "#/$defs/DeltaToAnchor" },
        "start_age": { "$ref": "#/$defs/StartAge" },
        "method": {
          "type": "string",
          "enum": ["three_days_one_year"]
        }
      }
    }
  },
  "properties": {
    "dayun": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "display_label_de",
        "direction",
        "direction_method",
        "start",
        "cycles",
        "current"
      ],
      "properties": {
        "label": { "type": "string", "description": "Stable English label, e.g. 'Da Yun'." },
        "display_label_de": { "type": "string", "description": "German display label, e.g. 'Dekaden-Säule'." },
        "direction": {
          "type": "string",
          "enum": ["forward", "backward"]
        },
        "direction_method": {
          "type": "string",
          "enum": ["year_stem_yinyang_and_sex", "explicit"]
        },
        "start": { "$ref": "#/$defs/Start" },
        "cycles": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "items": { "$ref": "#/$defs/Cycle" }
        },
        "current": {
          "oneOf": [
            { "$ref": "#/$defs/CurrentCycle" },
            { "type": "null" }
          ],
          "description": "The decade that currently covers as_of_date. May be null when no decade covers as_of_date (e.g. as_of_date precedes the first cycle)."
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "ruleset_id", "solar_terms_source", "computed_at"],
      "properties": {
        "source": { "const": "FuFirE" },
        "ruleset_id": { "const": "dayun_v1" },
        "solar_terms_source": { "type": "string" },
        "computed_at": { "type": "string", "format": "date-time" }
      }
    },
    "precision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["birth_time_known", "direction_basis", "provisional_fields"],
      "properties": {
        "birth_time_known": { "type": "boolean" },
        "direction_basis": {
          "type": ["string", "null"],
          "enum": ["explicit", "year_stem_yinyang_and_sex", null]
        },
        "provisional_fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
